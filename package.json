{
  "name": "redux",
  "version": "5.0.1",
  "description": "A JS library for predictable and maintainable global state management",
  "license": "MIT",
  "homepage": "https://redux.js.org",
  "repository": "github:reduxjs/redux",
  "bugs": "https://github.com/reduxjs/redux/issues",
  "keywords": [
    "redux",
    "reducer",
    "state",
    "predictable",
    "functional",
    "immutable",
    "hot",
    "live",
    "replay",
    "flux",
    "elm"
  ],
  "authors": [
    "Dan Abramov <dan.abramov@me.com> (https://github.com/gaearon)",
    "Andrew Clark <acdlite@me.com> (https://github.com/acdlite)"
  ],
  "main": "dist/cjs/redux.cjs",
  "module": "dist/redux.legacy-esm.js",
  "types": "dist/redux.d.ts",
  "unpkg": "dist/redux.browser.mjs",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "module-sync": {
        "types": "./dist/redux.d.mts",
        "default": "./dist/redux.mjs"
      },
      "module": {
        "types": "./dist/redux.d.mts",
        "default": "./dist/redux.mjs"
      },
      "browser": {
        "import": {
          "types": "./dist/redux.d.mts",
          "default": "./dist/redux.browser.mjs"
        },
        "default": {
          "types": "./dist/redux.d.ts",
          "default": "./dist/cjs/redux.cjs"
        }
      },
      "import": {
        "types": "./dist/redux.d.mts",
        "default": "./dist/redux.mjs"
      },
      "default": {
        "types": "./dist/redux.d.ts",
        "default": "./dist/cjs/redux.cjs"
      }
    }
  },
  "files": [
    "dist/",
    "src/"
  ],
  "scripts": {
    "clean": "rimraf dist/ coverage/",
    "format": "prettier --write \"{src,test}/**/*.{js,ts}\" \"**/*.md\"",
    "format:check": "prettier --list-different \"{src,test}/**/*.{js,ts}\" \"**/*.md\"",
    "lint": "eslint --ext js,ts src test",
    "test": "vitest --run --typecheck",
    "type-tests": "tsc -p tsconfig.test.json --noEmit",
    "test:watch": "vitest --watch",
    "test:cov": "vitest --coverage",
    "build": "yarn clean && tsdown --config-loader=unrun --config=${INIT_CWD}/tsdown.config.mts",
    "prepublishOnly": "yarn clean && yarn format:check && yarn lint && yarn test",
    "prepack": "yarn build",
    "examples:lint": "eslint --ext js,ts examples",
    "tsc": "tsc"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@babel/core": "^8.0.1",
    "@babel/helper-module-imports": "^8.0.0",
    "@babel/helper-plugin-utils": "^8.0.1",
    "@babel/types": "^8.0.0",
    "@types/node": "^26.0.1",
    "@typescript-eslint/eslint-plugin": "^7.3.1",
    "@typescript-eslint/parser": "^7.3.1",
    "cross-env": "^7.0.3",
    "esbuild": "^0.28.1",
    "eslint": "^8.57.0",
    "eslint-config-react-app": "^7.0.1",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "glob": "^10.3.10",
    "netlify-plugin-cache": "^1.0.3",
    "pkg-pr-new": "^0.0.75",
    "prettier": "^3.2.5",
    "rimraf": "^6.1.3",
    "rolldown": "^1.1.3",
    "rxjs": "^7.8.1",
    "tsdown": "^0.22.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "unrun": "^0.3.1",
    "vitest": "^4.0.5"
  },
  "resolutions": {
    "@typescript-eslint/eslint-plugin": "7.3.1",
    "@typescript-eslint/parser": "7.3.1"
  },
  "sideEffects": false,
  "packageManager": "yarn@4.4.1"
}
